{
  "name": "revaulter-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "e2e": "pnpm run e2e:build-server && playwright test",
    "e2e:build-server": "pnpm run build && mkdir -p ../../.bin && go build -tags e2e -o ../../.bin/revaulter-e2e ../../cmd/revaulter",
    "e2e:headed": "pnpm run e2e:build-server && playwright test --headed",
    "e2e:install": "playwright install --with-deps chromium",
    "format": "biome format --write .",
    "lint": "biome lint . && svelte-check",
    "lint:biome": "biome lint .",
    "lint:svelte": "svelte-check",
    "check": "biome check --write .",
    "svelte-check": "svelte-check",
    "test": "vitest run",
    "analyze": "cross-replace vite build --mode analyze"
  },
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "@fontsource-variable/geist": "5.2.8",
    "@fontsource-variable/geist-mono": "5.2.7",
    "arraybuffer-encoding": "1.1.0",
    "date-fns": "4.1.0",
    "hash-wasm": "4.12.0",
    "js-cookie": "3.0.5",
    "mlkem-wasm": "0.0.7",
    "tailwindcss": "4.2.2",
    "vite-bundle-analyzer": "1.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "1.59.1",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/vite": "4.2.2",
    "@tsconfig/svelte": "5.0.8",
    "@types/js-cookie": "3.0.6",
    "cross-replace": "0.2.0",
    "cssnano": "7.1.5",
    "postcss": "8.5.10",
    "postcss-import": "16.1.1",
    "postcss-url": "10.1.3",
    "svelte": "5.55.4",
    "svelte-check": "4.4.6",
    "typescript": "~5.9.3",
    "vite": "8.0.8",
    "vite-plugin-pwa": "1.2.0",
    "vite-plugin-sri-gen": "1.3.2",
    "vitest": "4.1.4"
  }
}
